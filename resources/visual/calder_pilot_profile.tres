[gd_resource type="Resource" script_class="PlayerVisualProfile" load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/visual/player_visual_profile.gd" id="1_profile"]

[resource]
script = ExtResource("1_profile")
