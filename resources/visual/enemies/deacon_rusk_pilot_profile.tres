[gd_resource type="Resource" script_class="EnemyVisualProfile" load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/visual/enemies/enemy_visual_profile.gd" id="1_profile"]

[resource]
script = ExtResource("1_profile")
profile_id = &"deacon_rusk_pilot"
enemy_id = &"deacon_rusk"
visual_mode = 1
use_procedural_pilot_frames = true
state_animation_map = {
"dead": "death",
"hurt": "hurt",
"idle": "idle",
"intro": "phase_transition",
"phase_transition": "phase_transition",
"reposition": "reposition",
"staggered": "stagger"
}
attack_phase_map = {
"active": "punch_combo",
"recovery": "idle",
"startup": "punch_combo"
}
